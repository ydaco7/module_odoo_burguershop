<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_burger_order_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="order">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row">
                            <div class="col-12 text-center">
                                <h2>Recibo de Pedido</h2>
                                <h3><t t-esc="order.name"/></h3>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-6">
                                <table class="table table-borderless table-sm">
                                    <tr>
                                        <td><strong>Cliente:</strong></td>
                                        <td><span t-field="order.partner_id"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Fecha:</strong></td>
                                        <td>
                                            <span t-field="order.date_order"
                                                  t-options='{"widget": "datetime"}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Estado:</strong></td>
                                        <td><span t-field="order.state"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <table class="table table-sm mt-3">
                            <thead class="table-dark">
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-center">Cant.</th>
                                    <th class="text-right">P. Unit.</th>
                                    <th>Extras</th>
                                    <th>Sin</th>
                                    <th class="text-right">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="order.order_line_ids" t-as="line">
                                    <tr>
                                        <td><span t-field="line.product_id"/></td>
                                        <td class="text-center">
                                            <span t-field="line.quantity"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line.unit_price"
                                                  t-options='{"widget": "float", "precision": 2}'/>
                                        </td>
                                        <td>
                                            <t t-foreach="line.extra_ingredient_ids" t-as="ing">
                                                <span class="badge badge-success">
                                                    + <t t-esc="ing.name"/>
                                                </span>
                                            </t>
                                        </td>
                                        <td>
                                            <t t-foreach="line.remove_ingredient_ids" t-as="ing">
                                                <span class="badge badge-danger">
                                                    - <t t-esc="ing.name"/>
                                                </span>
                                            </t>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line.subtotal"
                                                  t-options='{"widget": "float", "precision": 2}'/>
                                        </td>
                                    </tr>
                                    <t t-if="line.notes">
                                        <tr>
                                            <td colspan="6" class="text-muted font-italic">
                                                <t t-esc="line.notes"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr class="table-active">
                                    <td colspan="5" class="text-right">
                                        <strong>TOTAL</strong>
                                    </td>
                                    <td class="text-right">
                                        <strong>
                                            <span t-field="order.amount_total"
                                                  t-options='{"widget": "float", "precision": 2}'/>
                                        </strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <t t-if="order.state == 'returned'">
                            <div class="alert alert-warning mt-3">
                                <strong>PEDIDO DEVUELTO</strong><br/>
                                <span t-esc="order.return_reason"/>
                            </div>
                        </t>

                        <t t-if="order.notes">
                            <div class="mt-3">
                                <strong>Notas:</strong>
                                <span t-esc="order.notes"/>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
