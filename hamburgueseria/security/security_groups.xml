<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_burger" model="ir.module.category">
        <field name="name">Hamburguesería</field>
        <field name="description">Gestión de pedidos</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_burger_admin" model="res.groups">
        <field name="name">Administrador</field>
        <field name="category_id" ref="module_category_burger"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_burger_employee" model="res.groups">
        <field name="name">Empleado</field>
        <field name="category_id" ref="module_category_burger"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
