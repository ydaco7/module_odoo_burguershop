<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_burger_product_tree" model="ir.ui.view">
        <field name="name">burger.product.tree</field>
        <field name="model">burger.product</field>
        <field name="arch" type="xml">
            <tree string="Productos">
                <field name="name"/>
                <field name="product_type"/>
                <field name="price"/>
            </tree>
        </field>
    </record>

    <record id="view_burger_product_form" model="ir.ui.view">
        <field name="name">burger.product.form</field>
        <field name="model">burger.product</field>
        <field name="arch" type="xml">
            <form string="Producto">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre del producto"/></h1>
                    </div>
                    <group>
                        <group string="Información General">
                            <field name="product_type"/>
                            <field name="price"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ingredientes Disponibles"
                              attrs="{'invisible': [('product_type', '!=', 'burger')]}">
                            <field name="available_ingredient_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="ingredient_type"/>
                                    <field name="extra_price"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Descripción">
                            <field name="description" placeholder="Descripción del producto..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_burger_product_search" model="ir.ui.view">
        <field name="name">burger.product.search</field>
        <field name="model">burger.product</field>
        <field name="arch" type="xml">
            <search string="Buscar Productos">
                <field name="name" string="Producto"/>
                <filter string="Hamburguesas" name="burgers"
                        domain="[('product_type','=','burger')]"/>
                <filter string="Bebidas" name="drinks"
                        domain="[('product_type','=','drink')]"/>
                <filter string="Acompañamientos" name="sides"
                        domain="[('product_type','=','side')]"/>
                <separator/>
                <filter string="Archivados" name="inactive"
                        domain="[('active','=',False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Tipo" name="by_type"
                            context="{'group_by': 'product_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_burger_product" model="ir.actions.act_window">
        <field name="name">Productos</field>
        <field name="res_model">burger.product</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
